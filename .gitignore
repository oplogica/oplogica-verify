# ---- Python caches ----
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# ---- Virtual environments ----
.venv/
venv/
env/
ENV/

# ---- OS / editor cruft ----
.DS_Store
*.swp
.idea/
.vscode/

# ---- Generated demo artifacts ----
# The demo pipeline writes runtime artifacts into ./exports. These are
# regenerated by `python3 ova_demo/run_demo.py --out ./exports` and should NOT
# be committed by default — in particular the trust root contains freshly
# generated demo keys on every run.
exports/

# If you want to ship a FIXED, intentional example set, place curated copies
# under examples/ (committed) instead of exports/ (ignored). See README.
#
# Examples directory is tracked:
!examples/
!examples/**
